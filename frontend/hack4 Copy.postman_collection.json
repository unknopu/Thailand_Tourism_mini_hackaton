          "body": "{\n    \"conversation_id\": \"string\",\n    \"message_count\": 2,\n    \"messages\": [\n        {\n            \"id\": \"string_772bee34e7d44f9583610d711d23d954\",\n            \"role\": \"user\",\n            \"content\": \"หิวข้าวแกง\",\n            \"timestamp\": 1777640229.916416\n        },\n        {\n            \"id\": \"string_ab9ad65d5fd74dd5a6e56852ad22f8c7\",\n            \"role\": \"assistant\",\n            \"content\": \"Hungry for some good old-fashioned *khao gaeng*? Head to Chumphon’s Mu Ko Chumphon National Park — it’s a hidden gem with stunning sea views and fresh seafood right from the local boats! The laid-back island vibe fits your backpacker style, and you can enjoy a simple, delicious meal by the water after a hike through the mangrove forests or a swim among the limestone islands. Plus, it’s super budget-friendly and far from the crowds — perfect for a peaceful escape with nature.\",\n            \"timestamp\": 1777640230.154242\n        }\n    ]\n}"
