          "body": "{\n    \"total_conversations\": 1,\n    \"conversations\": [\n        {\n            \"conversation_id\": \"88\",\n            \"message_count\": 2,\n            \"messages\": [\n                {\n                    \"id\": \"88_c36a601dc1814074874c08dff8101fd5\",\n                    \"role\": \"user\",\n                    \"content\": \"หิวข้าวแกง\",\n                    \"timestamp\": 1777640235.687678\n                },\n                {\n                    \"id\": \"88_7f89cbf8afcc45eabe327b3580e81990\",\n                    \"role\": \"assistant\",\n                    \"content\": \"Hungry for some good old-fashioned *khao gaeng*? Head to Chumphon’s Mu Ko Chumphon National Park — it’s a hidden gem with stunning sea views and quiet beaches, perfect for your backpacker vibe. While it’s more nature-focused, you’ll find fresh seafood and simple local eats on nearby islands, matching your love for both noodles and seafood. Plus, it’s super low-key (only 3/10 crowd), ideal if you’re avoiding the masses. A little trek, a lot of serenity — and yes, dinner will be delicious.\",\n                    \"timestamp\": 1777640235.828438\n                }\n            ]\n        }\n    ]\n}"
